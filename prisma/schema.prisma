generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Anamnese {
  id                      String    @id @default(cuid())
  version                 Int       @default(2)
  gewaehlteAnwendung      String?
  mainFocus               String?
  mainFocus2              String?
  chamber2                Json      @default("{}")
  chamber2b               Json      @default("{}")
  recommendations         Json      @default("[]")
  kontraindikationen      Json      @default("{}")
  keineKontraindikationen Boolean   @default(false)
  vorname                 String
  nachname                String
  email                   String
  telefon                 String
  geburtsdatum            String
  adresse                 String
  consentDsgvo            Boolean
  consentGesundheitsdaten Boolean
  consentMarketing        Boolean   @default(false)
  signatureDataUrl        String?   @db.Text
  zielText                String?   @db.Text
  herkunft                String    @default("")
  userAgent               String    @default("")
  createdAt               DateTime  @default(now())
  customerId              String?
  customer                Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([createdAt])
}

model Customer {
  id               String         @id @default(cuid())
  vorname          String
  nachname         String
  email            String
  telefon          String
  geburtsdatum     String         @default("")
  adresse          String         @default("")
  status           CustomerStatus @default(neukunde)
  tags             String[]       @default([])
  consentMarketing  Boolean        @default(false)
  herkunft          String         @default("")
  erstTermin          DateTime?
  servicegesprachAm   DateTime?
  alternativeEmails   String[]  @default([])
  alternativeTelefone String[]  @default([])
  monatsKontingent    Int       @default(0)
  unbegrenzt          Boolean   @default(false)
  anamnesen           Anamnese[]
  empfehlungen      Empfehlung[]
  notizen           Note[]
  tasks             Task[]
  checkIns          CheckIn[]
  karten            Card[]
  leads             Lead[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([email])
  @@index([createdAt])
}

enum CustomerStatus {
  neukunde
  startangebot
  mitglied
  karten_kunde
  aggregator
  angebot_nachfassen
  kein_kauf
}

model Empfehlung {
  id            String        @id @default(cuid())
  customerId    String
  customer      Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  typ           EmpfehlungTyp
  anwendungen   Json
  einleitung    String?       @db.Text
  zusatzhinweis String?       @db.Text
  erkrankungen  Json          @default("[]")
  mitgliedschaft String?
  preisSnapshot Json          @default("{}")
  shareToken    String        @unique @default(cuid())
  pdfErzeugtAm  DateTime?
  sessionsProMonat Int?
  gueltigBis    DateTime?
  geoeffnetAm   DateTime?
  zugesagtAm    DateTime?
  createdAt     DateTime      @default(now())

  @@index([customerId])
}

enum EmpfehlungTyp {
  neukunde
  folge
}

model Note {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  body       String   @db.Text
  createdAt  DateTime @default(now())

  @@index([customerId])
}

model Task {
  id               String    @id @default(cuid())
  anweisung        String    @db.Text
  skript           String?   @db.Text
  customerId       String?
  customer         Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  erledigtAm       DateTime?
  erledigungsTyp   String?
  erledigungsNotiz String?   @db.Text
  faelligAm        DateTime?
  createdAt        DateTime  @default(now())

  @@index([erledigtAm])
  @@index([customerId])
}

model CheckIn {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  anwendung  String
  cardId     String?
  card       Card?    @relation(fields: [cardId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())

  @@index([customerId, createdAt])
  @@index([anwendung, createdAt])
}

model Card {
  id         String    @id @default(cuid())
  customerId String
  customer   Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  anwendung  String
  groesse    Int
  verbraucht Int       @default(0)
  gekauftAm  DateTime  @default(now())
  checkIns   CheckIn[]

  @@index([customerId, anwendung])
}

model LeadList {
  id             String    @id @default(cuid())
  name           String
  sheetUrl       String
  sheetId        String
  gid            String?
  nameModus      String    @default("getrennt")
  spalteName     String?
  spalteVorname  String?
  spalteNachname String?
  spalteEmail    String?
  spalteTelefon  String?
  aktiv          Boolean   @default(true)
  lastSyncedAt   DateTime?
  syncFehler     String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  leads          Lead[]
}

model Lead {
  id                 String     @id @default(cuid())
  leadListId         String
  leadList           LeadList   @relation(fields: [leadListId], references: [id], onDelete: Cascade)
  vorname            String     @default("")
  nachname           String     @default("")
  email              String     @default("")
  telefon            String     @default("")
  dedupeKey          String
  status             LeadStatus @default(neu)
  erreichtAm         DateTime?
  terminVereinbartAm DateTime?
  notiz              String?    @db.Text
  customerId         String?
  customer           Customer?  @relation(fields: [customerId], references: [id], onDelete: SetNull)
  createdAt          DateTime   @default(now())

  @@unique([leadListId, dedupeKey])
  @@index([status])
  @@index([customerId])
}

enum LeadStatus {
  neu
  erreicht
  termin_vereinbart
  kein_interesse
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  role      String   @default("STAFF")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
