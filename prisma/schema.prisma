generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Anamnese {
  id                      String    @id @default(cuid())
  version                 Int       @default(2)
  gewaehlteAnwendung      String?
  mainFocus               String?
  mainFocus2              String?
  chamber2                Json      @default("{}")
  chamber2b               Json      @default("{}")
  recommendations         Json      @default("[]")
  kontraindikationen      Json      @default("{}")
  keineKontraindikationen Boolean   @default(false)
  vorname                 String
  nachname                String
  email                   String
  telefon                 String
  geburtsdatum            String
  adresse                 String
  consentDsgvo            Boolean
  consentGesundheitsdaten Boolean
  consentMarketing        Boolean   @default(false)
  signatureDataUrl        String?   @db.Text
  herkunft                String    @default("")
  userAgent               String    @default("")
  createdAt               DateTime  @default(now())
  customerId              String?
  customer                Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
}

model Customer {
  id               String         @id @default(cuid())
  vorname          String
  nachname         String
  email            String         @unique
  telefon          String
  geburtsdatum     String
  adresse          String
  status           CustomerStatus @default(neukunde)
  tags             String[]       @default([])
  consentMarketing  Boolean        @default(false)
  herkunft          String         @default("")
  erstTermin        DateTime?
  servicegesprachAm DateTime?
  anamnesen         Anamnese[]
  empfehlungen      Empfehlung[]
  notizen           Note[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
}

enum CustomerStatus {
  neukunde
  startangebot
  mitglied
  karten_kunde
  aggregator
  angebot_nachfassen
  kein_kauf
}

model Empfehlung {
  id            String        @id @default(cuid())
  customerId    String
  customer      Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  typ           EmpfehlungTyp
  anwendungen   Json
  einleitung    String?       @db.Text
  zusatzhinweis String?       @db.Text
  preisSnapshot Json          @default("{}")
  shareToken    String        @unique @default(cuid())
  pdfErzeugtAm  DateTime?
  createdAt     DateTime      @default(now())
}

enum EmpfehlungTyp {
  neukunde
  folge
  experte
}

model Note {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  body       String   @db.Text
  createdAt  DateTime @default(now())
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  role      String   @default("STAFF")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
